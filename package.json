{
  "name": "tradering-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Local AI crypto signal scanner with Vercel-compatible dashboard",
  "scripts": {
    "dev": "chcp 65001 >nul && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "local:api": "chcp 65001 >nul && tsx src/local/index.ts",
    "local:all": "concurrently -n API,DASH -c cyan,magenta \"npm run local:api\" \"npm run dev\"",
    "validate:live": "tsx scripts/final-live-validation.ts",
    "signal:test": "chcp 65001 >nul && tsx scripts/real-signal-test.ts",
    "position:test": "chcp 65001 >nul && tsx scripts/position-sizing-validation.ts",
    "okx:diagnostics": "chcp 65001 >nul && tsx scripts/okx-diagnostics.ts",
    "kraken:diagnostics": "chcp 65001 >nul && tsx scripts/kraken-diagnostics.ts",
    "aigensyn:bybit": "chcp 65001 >nul && tsx scripts/manual-aigensyn-bybit.ts",
    "aigensyn:watch": "chcp 65001 >nul && set WATCH_AIGENSYN=1&& tsx scripts/manual-aigensyn-bybit.ts",
    "priority:watch": "chcp 65001 >nul && set PRIORITY_WATCH=1&& tsx scripts/manual-aigensyn-bybit.ts",
    "priority:watchers": "chcp 65001 >nul && tsx scripts/priority-watchers.ts",
    "startup:notify": "chcp 65001 >nul && tsx scripts/startup-notify.ts",
    "telegram:format-test": "chcp 65001 >nul && tsx scripts/telegram-format-test.ts",
    "telegram:menu-test": "chcp 65001 >nul && tsx scripts/telegram-menu-test.ts",
    "telegram:button-test": "chcp 65001 >nul && tsx scripts/telegram-button-handler-test.ts",
    "telegram:entry-only-test": "chcp 65001 >nul && tsx scripts/telegram-real-entry-only-test.ts",
    "telegram:silent-proof": "chcp 65001 >nul && tsx scripts/telegram-silent-live-proof.ts",
    "telegram:live-session": "chcp 65001 >nul && tsx scripts/telegram-live-session-verification.ts",
    "telegram:real-flow-test": "chcp 65001 >nul && tsx scripts/telegram-real-flow-validation.ts",
    "paper:simulation-test": "chcp 65001 >nul && tsx scripts/paper-simulation-test.ts",
    "newtokens:test": "chcp 65001 >nul && tsx scripts/bybit-new-token-scan-test.ts",
    "watchlist:test": "chcp 65001 >nul && tsx scripts/watchlist-evolution-test.ts",
    "sniper:test": "chcp 65001 >nul && tsx scripts/sniper-entry-test.ts",
    "stats:test": "chcp 65001 >nul && tsx scripts/stats-performance-test.ts",
    "intelligence:test": "chcp 65001 >nul && tsx scripts/intelligence-bots-live-test.ts",
    "intelligence:impact-test": "chcp 65001 >nul && tsx scripts/intelligence-impact-live-validation.ts",
    "market:registry-test": "chcp 65001 >nul && tsx scripts/market-registry-validation.ts",
    "typecheck": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "next": "^16.2.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "eslint": "^9.19.0",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
